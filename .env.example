# .env.example
# 請複製此檔案並重新命名為 .env，然後填入您的金鑰

# Discord 配置
DISCORD_BOT_TOKEN=YOUR_DISCORD_BOT_TOKEN_HERE

# AI 代理配置 (Anthropic/OpenAI compatible)
AI_API_KEY=YOUR_AI_API_KEY_HERE
# Docker 環境請使用 http://host.docker.internal:10909
# 本地環境請使用 http://localhost:10909
AI_API_BASE=http://host.docker.internal:10909
AI_MODEL_ID=gemini-3-flash

# 外部工具 API Keys
TAVILY_API_KEY=your_tavily_key
OPENROUTER_API_KEY=your_openrouter_key

# 系統配置
TZ=Asia/Taipei
PYTHONUNBUFFERED=1
