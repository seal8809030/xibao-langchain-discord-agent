FROM mingc/android-build-box:latest

ENV ANDROID_HOME=/opt/android-sdk
ENV GRADLE_USER_HOME=/root/.gradle
ENV JAVA_HOME=/usr/lib/jvm/java-21-openjdk-amd64

WORKDIR /project

# Copy project files
COPY . /project/

# Fix gradlew line endings and permissions
RUN sed -i 's/\r//' gradlew && chmod +x gradlew

# Pre-extract Gradle from local zip (avoid network issues)
RUN java -classpath gradle/wrapper/gradle-wrapper.jar \
    org.gradle.wrapper.GradleWrapperMain \
    assembleDebug --no-daemon \
    -Dorg.gradle.user.home=/root/.gradle 2>&1
